<?xml version='1.0' standalone='yes'?>

<!DOCTYPE PLUGIN [
<!ENTITY name        "unbalanced-dev">
<!ENTITY author      "dev">
<!ENTITY version     "##version##">
<!ENTITY pluginURL   "##pluginURL##">
<!ENTITY bundle      "&name;-&version;.tgz">
<!ENTITY md5         "##md5##">
<!ENTITY bundleURL   "##bundleURL##">
]>

<PLUGIN  name="&name;"
         author="&author;"
         version="&version;"
         pluginURL="&pluginURL;"
>

<CHANGES>
dev build &version;
</CHANGES>

<!--
Get the unbalanced-dev bundle.
-->
<FILE Name="/boot/config/plugins/&name;/&bundle;">
<URL>"&bundleURL;"</URL>
<MD5>&md5;</MD5>
</FILE>

<!-- Install default plugin cfg -->
<FILE Name="/boot/config/plugins/&name;/&name;.cfg">
<INLINE>
<![CDATA[
SERVICE="disable"
PORT="7091"
RUNAS="nobody"
]]>
</INLINE>
</FILE>

<!-- Install default plugin env -->
<FILE Name="/boot/config/plugins/&name;/&name;.env">
<INLINE>
<![CDATA[
DRY_RUN=true
NOTIFY_PLAN=0
NOTIFY_TRANSFER=0
RESERVED_AMOUNT=1
RESERVED_UNIT=Gb
RSYNC_ARGS=-X
VERBOSITY=0
REFRESH_RATE=1000
]]>
</INLINE>
</FILE>

<!--
Prepare for installation.
-->
<FILE Run="/bin/bash">
<INLINE>
running=$(pidof unbalanced-dev | wc -w)

# Remove emhttp files so we can re-install.
rm -rf /usr/local/emhttp/plugins/&name;/* 2>/dev/null

# Remove old 'bundle' files.
rm -f $(ls /boot/config/plugins/&name;/&name;*.tgz 2>/dev/null | grep -v '&version;.tgz')

# Install the 'bundle'.
tar -xf /boot/config/plugins/&name;/&bundle; -C /usr/local/emhttp/plugins

# start the plugin if it was running previously
if [ $running -eq 1 ]; then
	/usr/local/emhttp/plugins/&name;/scripts/start
fi

echo "-----------------------------------------------------------"
echo " unbalanced-dev has been installed."
echo " Version: &version;"
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

<!--
The 'remove' script.
-->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
/usr/local/emhttp/plugins/&name;/scripts/stop
rm -rf /usr/local/emhttp/plugins/&name;
rm -rf /boot/config/plugins/&name;

echo ""
echo "-----------------------------------------------------------"
echo " unbalanced-dev has been removed."
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

</PLUGIN>
